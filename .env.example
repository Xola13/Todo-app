# Copy this file to .env.local and fill in your own values.
#   cp .env.example .env.local
#
# Vue CLI only exposes variables prefixed with VUE_APP_ to the app.
# .env.local is gitignored, so your key stays out of version control.
# NEVER put a real key in THIS file — it is committed to git.
#
# Get a free Groq key at: https://console.groq.com/keys

VUE_APP_GROQ_API_KEY=
VUE_APP_GROQ_MODEL=openai/gpt-oss-20b

# --- Production (Netlify) ---
# For the LIVE site, do NOT use VUE_APP_GROQ_API_KEY (it would ship in the JS
# bundle). Instead, in the Netlify dashboard (Site settings > Environment
# variables) set:
#   GROQ_API_KEY     = your key   (server-side secret, used by netlify/functions/groq.js)
#   VUE_APP_AI_PROXY = true       (tells the app to call the /api/groq proxy)
VUE_APP_AI_PROXY=
