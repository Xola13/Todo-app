# Copy this file to .env.local and fill in your own values.
#   cp .env.example .env.local
#
# Vue CLI only exposes variables prefixed with VUE_APP_ to the app.
# .env.local is gitignored, so your key stays out of version control.
#
# Get a free Groq key at: https://console.groq.com/keys

VUE_APP_GROQ_API_KEY=
VUE_APP_GROQ_MODEL=openai/gpt-oss-20b
